# Polymarket Trading Configuration
# Copy this to .env and fill in your values

# Required for trading (not needed for scanning/analysis)
POLY_PRIVATE_KEY=0x_your_private_key_here

# Optional: API credentials (derived from private key if not set)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Google Custom Search API (for agent web search)
GOOGLE_API_KEY=
GOOGLE_SEARCH_CX=

# Risk management
BANKROLL=5.00
MAX_BET_FRACTION=0.10
STOP_LOSS_PCT=0.50
