{
  "manifest_version": 3,
  "name": "PolyBillionaire Search Proxy",
  "version": "1.3",
  "description": "Local search proxy for PolyBillionaire trading agents",
  "permissions": ["alarms", "scripting", "tabs"],
  "host_permissions": [
    "https://www.google.com/*",
    "http://localhost:3456/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
